# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=

# AI provider: deepseek (default) | openai | gemini | claude
AI_PROVIDER=deepseek

# Model override (optional — each provider has a sensible default)
# deepseek default: deepseek-chat
# openai   default: gpt-4o-mini
# gemini   default: gemini-2.5-flash
# claude   default: claude-sonnet-4-6
# AI_MODEL=

# Claude via Max subscription (OAuth token, starts with sk-ant-oat01-).
# Required when AI_PROVIDER=claude. Billed against your Claude Max plan,
# NOT the pay-as-you-go API. Get it from the Claude Code CLI login.
# Available models: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# CLAUDE_CODE_OAUTH_TOKEN=

# DeepSeek API key — required when AI_PROVIDER=deepseek
# https://platform.deepseek.com
DEEPSEEK_API_KEY=

# OpenAI API key — required when AI_PROVIDER=openai
# https://platform.openai.com
OPENAI_API_KEY=

# Google Gemini API key — always required (used by the router even when AI_PROVIDER≠gemini)
# https://aistudio.google.com
GEMINI_API_KEY=

# Router provider: gemini (default, fast) | deepseek | openai
# Controls the simple/complex classifier only — can also be changed per-guild via /ai router
# ROUTER_PROVIDER=gemini

# Router model override (optional)
# gemini default: gemini-2.5-flash-lite
# ROUTER_MODEL=

# Name of the channel the bot listens in (default: ai-chat)
AI_CHANNEL_NAME=ai-chat

# Enable web search tools (search_web / fetch_url). Set to false to disable.
# Requires Windows Search API running on WINDOWS_API_HOST:7654
WEB_SEARCH_ENABLED=true

# Host of the Windows Search API (default: localhost)
# Set to your Windows PC's Tailscale IP if running remotely
WINDOWS_API_HOST=localhost
