# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=

# DeepSeek API key (https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# Google Gemini API key (https://aistudio.google.com)
GEMINI_API_KEY=

# Name of the channel the bot listens in (default: ai-chat)
AI_CHANNEL_NAME=ai-chat

# Enable web search tools (search_web / fetch_url). Set to false to disable.
# Requires Windows Search API running on WINDOWS_API_HOST:7654
WEB_SEARCH_ENABLED=true

# Host of the Windows Search API (default: localhost)
# Set to your Windows PC's Tailscale IP if running remotely
WINDOWS_API_HOST=localhost
